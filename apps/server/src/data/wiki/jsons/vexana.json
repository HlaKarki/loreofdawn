  {
    "title": "Story",
    "depth": 0,
    "paragraphs": [
      {
        "sentences": [
          {
            "text": "\"The young duchess guarding Necrokeep.\""
          }
        ]
      },
      {
        "sentences": [
          {
            "text": "Vexana was the majestic ruler of Necrokeep, the gentle mother of the undead, but also the only glimmer of light that penetrated the Mist, bringing hope to this cursed land shunned by both life and death.",
            "links": [
              {
                "type": "internal",
                "page": "Necrokeep"
              }
            ]
          }
        ]
      }
    ],
