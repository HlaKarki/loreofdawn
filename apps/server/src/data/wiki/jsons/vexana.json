  {
    "title": "Song of the Old Days",
    "depth": 1,
    "paragraphs": [
      {
        "sentences": [
          {
            "text": "I want to live"
          },
          {
            "text": "To wake up with thee"
          },
          {
            "text": "When the world is sound asleep"
          },
          {
            "text": "Tender is the morning dew"
          },
          {
            "text": "Upon the sun rays set free"
          }
        ]
      },
      {
        "sentences": [
          {
            "text": "I want to live"
          },
          {
            "text": "To walk among spring flowers"
          },
          {
            "text": "And tread on fallen leaves"
          },
          {
            "text": "Too cold the moonlit snow"
          },
          {
            "text": "Melt into humid summer breeze"
          }
        ]
      },
      {
        "sentences": [
          {
            "text": "I want to live"
          },
          {
            "text": "To sip the morning brew"
          },
          {
            "text": "As the scent climbs up the eaves"
          },
          {
            "text": "To share joy and sorrow"
          },
          {
            "text": "Taste all the bittersweet"
          }
        ]
      },
      {
        "sentences": [
          {
            "text": "Thy warmth, thy breaths"
          },
          {
            "text": "And blossoming smiles"
          },
          {
            "text": "How I want to live"
          },
          {
            "text": "To wait for thy return"
          },
          {
            "text": "Till all the greens and colors no longer be"
          }
        ]
      },
      {
        "sentences": [
          {
            "text": "O how I want to live"
          },
          {
            "text": "For aged laughter"
          },
          {
            "text": "For newborn innocence"
          },
          {
            "text": "For birds on wings"
          },
          {
            "text": "For lingering melodies"
          }
        ]
      },
      {
        "sentences": [
          {
            "text": "Shall I bear all the sins"
          },
          {
            "text": "For thee to come back to me Tell me all the suffering"
          },
          {
            "text": "Is but a ghostly dream"
          }
        ]
      }
    ]
  },
