    "depth": 0,
    "paragraphs": [
      {
        "sentences": [
          {
            "text": "\"The owl scholar who can control time\""
          }
        ]
      },
      {
        "sentences": [
          {
            "text": "Diggie is a scholar from Eruditio.",
            "links": [
              {
                "type": "internal",
                "page": "Eruditio"
              }
            ]
          },
          {
            "text": "With his \"Time Nest\" Diggie can turn back time and even take others to a time travel with him unhindered by any outside forces."
          }
        ]
      }
    ],
