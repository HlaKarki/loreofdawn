              {
                "type": "internal",
                "page": "Dagger"
              },
              {
                "type": "internal",
                "page": "Boots"
              },
              {
                "text": "physical damage",
                "type": "internal",
                "page": "Physical attack"
              }
            ]
          },
          {
            "text": "If you are a sustain or tank hero like, , , , , , , and replace Dagger with Leather Jerkin or Magic Resist Cloak (depends on lane enemy damage type)",
            "links": [
