  {
    "title": "Story",
    "depth": 0,
    "paragraphs": [
      {
        "sentences": [
          {
            "text": "\"Stone man awakened from sleep\""
          }
        ]
      },
      {
        "sentences": [
          {
            "text": "The stone man who signed a contract with the Ancient Ones has a kind-hearted nature and infinite power."
          },
          {
            "text": "He sleeps most of his life."
          },
          {
            "text": "After Grock woke up, he found that the Ancient Ones he was guarding had disappeared, so he carried the Castle of the Ancient Ones on his shoulders and walked out of the mountains to find the whereabouts of the Ancient Ones."
          }
        ]
      }
