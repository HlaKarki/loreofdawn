      {
        "sentences": [
          {
            "text": "Heroes are the playable characters in Mobile Legends: Bang Bang.",
            "links": [
              {
                "type": "internal",
                "page": "Mobile Legends: Bang Bang"
              }
            ],
            "formatting": {
              "bold": [
                "Heroes"
              ],
              "italic": [
                "Mobile Legends: Bang Bang"
              ]
            }
          },
          {
            "text": "Each has a unique ability known as a skill.",
            "links": [
              {
                "text": "skill",
                "type": "internal",
                "page": "skill"
              }
            ]
          },
          {
            "text": "Because the outcome of the match is dependent on their intervention."
          },
          {
            "text": "During a match, two opposing teams choose five heroes out of 128 to gain experience and gold and level up their abilities in order to destroy the opponent's base."
          },
          {
            "text": "Most heroes have a distinct role that defines how they affect the battlefield, though many heroes can play multiple roles.",
            "links": [
              {
                "text": "role",
                "type": "internal",
                "page": "role"
              }
            ]
          }
        ]
      }
