  {
    "title": "Hero updates",
    "depth": 0,
    "paragraphs": [
      {
        "sentences": [
          {
            "text": "Heroes can rise and fall, and eventually be forgotten, so they have the potential to be upgraded to new and improved gameplay and visual standards known as a revamp."
          }
        ]
      }
    ],
    "templates": [
      {
        "list": [
