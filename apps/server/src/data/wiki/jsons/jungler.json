    "lists": [
      [
        {
          "text": "Assassin Jungler: heroes who have larger advantages such as High Mobility, Burst Damage and Fast Farming but they fell off when it reaches to late game. Assassins are part of this category."
        }
      ],
      [
        {
          "text": "Late Game Jungler: heroes who were weak in the early they must farm as much as possible to earn their potential. Fighters and Assassin are part of this category."
        }
      ],
      [
        {
          "text": "Hybrid Jungler: heroes who are fused with high durability and high damage they can be either deal high damage in the early game or earned their potential on the late game. Fighters are part of this category."
        }
      ],
      [
        {
          "text": "Tank Jungler: heroes who have high durability but low damage and slow farming however they can act as the frontliners protecting their squishy teammates and soaking up damage to the enemies. Tanks are part of this category."
        }
      ],
      [
        {
          "text": "Ranged Jungler: heroes who only have ranged basic attack and skills who can farm faster but they are shown to be disadvantaged in team fights cause of their lack of mobility. Marksmen and Mage heroes are part of this category."
        }
      ]
    ]
