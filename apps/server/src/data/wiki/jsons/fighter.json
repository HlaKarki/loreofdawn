    "paragraphs": [
      {
        "sentences": [
          {
            "text": "Fighters are close-range combatants that possess a mixture of offensive and defensive capabilities.",
            "formatting": {
              "bold": [
                "Fighters"
              ]
            }
          },
          {
            "text": "A fighter's damage will add up over time to make it a major threat.",
            "formatting": {
              "bold": [
                "fighter's"
              ]
            }
          },
          {
            "text": "Each fighter has a unique blend of mobility, damage, disruption and durability.",
            "formatting": {
              "bold": [
                "fighter"
              ]
            }
          },
          {
            "text": "The role of a Fighter is an intermediate melee hero, between durability or damage, hence makes fighters serve as multi-purpose combatant, such as the Semi-Tank, Crowd Controller, or Burst Damage Dealer.",
            "formatting": {
              "bold": [
                "Fighter"
              ]
            }
          }
        ]
      },
      {
        "sentences": [
          {
            "text": "Fighters are classified into three types: pure, primary, and secondary."
          }
        ]
      }
