      [
        {
          "text": "Late Game Gold: heroes who were disadvantaged and weak at the start as the game progresses they became very strong carries on the late game"
        }
      ],
      [
        {
          "text": "Burst Gold: heroes who deal amount of high damage on the early game either fell off its effectiveness in the late game or keep its strength"
        }
      ],
      [
        {
          "text": "Magic Gold: heroes who deal exclusively magic damage early and up to late game having greater advantages towards their opponents. Mages and Magic Damage speciality Marksmen are part of this category"
        }
